CREATE TABLE courses (
    id INTEGER PRIMARY KEY,
    module_name TEXT NOT NULL,
    teacher TEXT NOT NULL,
    semester TEXT NOT NULL,
    status TEXT NOT NULL,
    grade TEXT NOT NULL,
    notes TEXT
);

